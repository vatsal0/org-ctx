# The dummy org is its own standalone git repository (it has scripted commit
# history that IS the demo data). We must not let the parent repo swallow its
# .git directory, or `git` subprocess calls that target dummy-org/ would resolve
# to the parent repo instead.
dummy-org/.git/

# The shared graph store is generated at runtime by `orgctx extract/ingest`.
# We keep the directory (with its checked-in doc.md) but ignore the artifacts.
central/graph.db
central/entities/

# Per-repo agent payloads are generated by `orgctx sync`; regenerable, not source.
dummy-org/*/.orgcontext/

# Eval outputs (plots) are regenerable.
eval/out/

# Standard Python noise.
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
